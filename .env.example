# Copy to .env and fill with the TiDB Zero / TiDB Cloud Starter connection details.
# Do not commit .env.
TIDB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=<cluster-prefix>.root
TIDB_PASSWORD=<generated-password>
TIDB_DATABASE=test

# TiDB Cloud Starter/Essential public endpoints require TLS.
# Set to false only for a local/self-managed test cluster.
TIDB_SSL=true

# Optional: drop/recreate the demo table before import.
TIDB_RESET=false
