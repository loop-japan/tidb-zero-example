{
  "name": "tidb-zero-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TiDB Zero demo scaffold for data import, vector search, and full-text search testing.",
  "scripts": {
    "dry-run": "tsx src/import-and-test.ts --dry-run",
    "demo": "tsx src/import-and-test.ts",
    "web": "tsx src/web-server.ts",
    "start:web": "tsx src/web-server.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/import-and-test.js",
    "tidb-zero:env": "tsx src/tidb-zero-env.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "mysql2": "^3.11.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@types/node": "^24.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
